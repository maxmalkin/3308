#!/bin/sh

cd "$(git rev-parse --show-toplevel)/ProjectSourceCode" || exit 1

echo "Running format check..."
pnpm biome check 2>&1

if [ $? -ne 0 ]; then
  echo "Unformatted files detected. Run 'pnpm format' and commit before pushing."
  exit 1
fi

echo "Running typecheck..."
pnpm tsc --build --noEmit 2>&1

if [ $? -ne 0 ]; then
  echo "Typecheck failed."
  exit 1
fi
